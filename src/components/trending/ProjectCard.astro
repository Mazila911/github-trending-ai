---
import type { Project } from '../../types/index';
import { formatStars, getLanguageColor } from '../../lib/format';
import Badge from '../ui/Badge.astro';

interface Props {
  project: Project;
  rank: number;
}

const { project, rank } = Astro.props;

const description = project.description_zh || project.description || '';
const starsFormatted = formatStars(project.stargazers_count);
const forksFormatted = formatStars(project.forks_count);
const languageColor = project.language ? getLanguageColor(project.language) : null;

const rankColorClass = rank === 1
  ? 'text-[var(--color-rank-gold)]'
  : rank === 2
    ? 'text-[var(--color-rank-silver)]'
    : rank === 3
      ? 'text-[var(--color-rank-bronze)]'
      : 'text-[var(--color-text-muted)]';

const history = project.trending_history || [];
const previousRank = history.length > 1 ? history[1].rank : null;
const firstSeen = project.first_seen_at ? new Date(project.first_seen_at) : null;
const daysSinceFirstSeen = firstSeen ? (Date.now() - firstSeen.getTime()) / (1000 * 60 * 60 * 24) : 999;
const isNew = daysSinceFirstSeen <= 7;
let rankChange: 'up' | 'down' | 'same' | 'new' = 'same';
let rankDiff = 0;

if (isNew) {
  rankChange = 'new';
} else if (history.length > 1 && previousRank !== null) {
  rankDiff = previousRank - rank;
  if (rankDiff > 0) rankChange = 'up';
  else if (rankDiff < 0) rankChange = 'down';
}

const todayRecord = history.length > 0 ? history[0] : null;
const starsGained = todayRecord?.stars_gained || 0;
const aiScore = project.ai_quality_score;
---

<a
  href={`/repo/${project.owner_login}/${project.name}`}
  class="project-card block rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-lg hover:border-[var(--color-accent)]/30"
>
  <div class="flex items-start gap-4">
    <div class="flex flex-col items-center gap-1 shrink-0 w-8">
      <span class:list={['text-xl font-bold leading-none', rankColorClass]}>
        {rank}
      </span>
      {rankChange === 'new' && (
        <span class="text-[10px] font-bold px-1 py-0.5 rounded bg-[var(--color-accent)]/15 text-[var(--color-accent)]">NEW</span>
      )}
      {rankChange === 'up' && (
        <span class="flex items-center text-[10px] font-medium text-[var(--color-success)]">
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor"><path d="M6 2l4 5H2z"/></svg>
          {rankDiff}
        </span>
      )}
      {rankChange === 'down' && (
        <span class="flex items-center text-[10px] font-medium text-[var(--color-danger)]">
          <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor"><path d="M6 10l4-5H2z"/></svg>
          {Math.abs(rankDiff)}
        </span>
      )}
    </div>

    <img
      src={project.owner_avatar_url}
      alt={`${project.owner_login} avatar`}
      class="w-10 h-10 rounded-full shrink-0"
      loading="lazy"
      width="40"
      height="40"
    />

    <div class="flex-1 min-w-0">
      <h3 class="text-base font-semibold text-[var(--color-text-primary)] truncate">
        <span class="text-[var(--color-text-secondary)]">{project.owner_login}</span>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span>{project.name}</span>
      </h3>

      <p class="mt-1 text-sm text-[var(--color-text-secondary)] line-clamp-2">
        {description}
      </p>

      <div class="mt-3 flex flex-wrap items-center gap-3 text-xs">
        <span class="inline-flex items-center gap-1 text-[var(--color-star)]">
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
          {starsFormatted}
        </span>

        {starsGained > 0 && (
          <span class="inline-flex items-center gap-1 text-[var(--color-success)] font-medium">
            +{starsGained} stars today
          </span>
        )}

        {project.language && languageColor && (
          <span class="inline-flex items-center gap-1.5 text-[var(--color-text-secondary)]">
            <span class="w-3 h-3 rounded-full shrink-0" style={`background-color: ${languageColor}`}></span>
            {project.language}
          </span>
        )}

        <span class="inline-flex items-center gap-1 text-[var(--color-text-muted)]">
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878zm3.75 7.378a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm3-8.75a.75.75 0 100-1.5.75.75 0 000 1.5z"/></svg>
          {forksFormatted}
        </span>

        {aiScore > 0 && (
          <Badge text={`AI ${(aiScore / 10).toFixed(1)}`} variant="accent" size="sm" />
        )}
      </div>
    </div>
  </div>
</a>
