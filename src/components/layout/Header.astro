---
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/trending', label: '榜单' },
  { href: '/collections', label: '专题' },
  { href: '/projects', label: '全部项目' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors duration-200">
      <span>GTAI</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 rounded-[var(--radius-md)] text-sm font-medium transition-colors duration-200',
              currentPath === link.href
                ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Theme Toggle -->
    <button
      id="theme-toggle"
      type="button"
      class="flex items-center justify-center w-10 h-10 rounded-[var(--radius-md)] hover:bg-[var(--color-bg-hover)] transition-colors duration-200"
      aria-label="切换主题"
    >
      <!-- Sun icon (shown in dark mode) -->
      <svg id="theme-icon-sun" class="w-5 h-5 text-[var(--color-text-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
      </svg>
      <!-- Moon icon (shown in light mode) -->
      <svg id="theme-icon-moon" class="w-5 h-5 text-[var(--color-text-secondary)] hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
      </svg>
    </button>

    <!-- Mobile Hamburger (CSS-only) -->
    <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
    <label
      for="mobile-menu-toggle"
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 cursor-pointer rounded-[var(--radius-md)] hover:bg-[var(--color-bg-hover)] transition-colors duration-200"
      aria-label="打开导航菜单"
    >
      <span class="block w-5 h-0.5 bg-[var(--color-text-primary)] transition-transform duration-200 peer-checked:translate-y-[3px] peer-checked:rotate-45"></span>
      <span class="block w-5 h-0.5 bg-[var(--color-text-primary)] mt-1 transition-opacity duration-200 peer-checked:opacity-0"></span>
      <span class="block w-5 h-0.5 bg-[var(--color-text-primary)] mt-1 transition-transform duration-200 peer-checked:-translate-y-[3px] peer-checked:-rotate-45"></span>
    </label>

    <!-- Mobile Menu Panel -->
    <div class="fixed inset-x-0 top-16 bottom-0 bg-[var(--color-bg-primary)]/95 backdrop-blur-md border-t border-[var(--color-border)] translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-in-out lg:hidden">
      <ul class="flex flex-col p-4 gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'block px-4 py-3 rounded-[var(--radius-md)] text-base font-medium transition-colors duration-200',
                currentPath === link.href
                  ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10'
                  : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)]',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<!-- Spacer to prevent content from hiding behind fixed header -->
<div class="h-16"></div>

<script>
  // Theme toggle logic - default dark, support light switch
  (function() {
    const toggle = document.getElementById('theme-toggle');
    const iconSun = document.getElementById('theme-icon-sun');
    const iconMoon = document.getElementById('theme-icon-moon');

    function getStoredTheme() {
      return localStorage.getItem('theme');
    }

    function setTheme(theme) {
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
        iconSun.classList.add('hidden');
        iconMoon.classList.remove('hidden');
      } else {
        document.documentElement.removeAttribute('data-theme');
        iconSun.classList.remove('hidden');
        iconMoon.classList.add('hidden');
      }
      localStorage.setItem('theme', theme);
    }

    // Initialize theme from localStorage (default: dark)
    const stored = getStoredTheme();
    if (stored === 'light') {
      setTheme('light');
    } else {
      setTheme('dark');
    }

    toggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      setTheme(current === 'light' ? 'dark' : 'light');
    });
  })();
</script>
