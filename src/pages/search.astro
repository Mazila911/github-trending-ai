---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索" description="搜索 AI 开源项目">
  <section class="max-w-4xl mx-auto px-4 py-8">
    <!-- Search Input -->
    <div class="mb-8">
      <div class="relative">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[var(--color-text-muted)]"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path d="M10.68 11.74a6 6 0 01-7.922-8.982 6 6 0 018.982 7.922l3.04 3.04a.749.749 0 01-.326 1.275.749.749 0 01-.734-.215l-3.04-3.04zM11.5 7a4.499 4.499 0 10-8.997 0A4.499 4.499 0 0011.5 7z"></path>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索项目、技术栈、关键词..."
          class="w-full pl-12 pr-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] text-base"
        />
      </div>
    </div>

    <!-- Results Count -->
    <div id="search-status" class="mb-4 text-sm text-[var(--color-text-secondary)] hidden"></div>

    <!-- Results Area -->
    <div id="search-results"></div>

    <!-- Empty State -->
    <div id="search-empty" class="hidden text-center py-16">
      <p class="text-[var(--color-text-secondary)] text-lg mb-6">未找到匹配的项目</p>
      <div class="flex flex-wrap justify-center gap-2" id="hot-tags-empty">
        <a href="/search?q=LLM" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">LLM</a>
        <a href="/search?q=RAG" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">RAG</a>
        <a href="/search?q=Agent" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">Agent</a>
        <a href="/search?q=Vector DB" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">Vector DB</a>
        <a href="/search?q=Fine-tuning" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">Fine-tuning</a>
        <a href="/search?q=MLOps" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">MLOps</a>
      </div>
    </div>

    <!-- Initial Hot Tags (shown before any search) -->
    <div id="search-initial" class="text-center py-16">
      <p class="text-[var(--color-text-secondary)] text-lg mb-6">热门搜索</p>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/search?q=LLM" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">LLM</a>
        <a href="/search?q=RAG" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">RAG</a>
        <a href="/search?q=Agent" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">Agent</a>
        <a href="/search?q=Vector DB" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">Vector DB</a>
        <a href="/search?q=Fine-tuning" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">Fine-tuning</a>
        <a href="/search?q=MLOps" class="px-3 py-1.5 rounded-full text-sm bg-[var(--color-bg-hover)] text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors">MLOps</a>
      </div>
    </div>
  </section>

  <script type="module">
    import * as pagefind from '/pagefind/pagefind.js';

    const HISTORY_KEY = 'gtai_search_history';
    const MAX_HISTORY = 10;

    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    const searchStatus = document.getElementById('search-status');
    const searchEmpty = document.getElementById('search-empty');
    const searchInitial = document.getElementById('search-initial');

    // Read ?q= param and pre-fill input
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') || '';
    if (initialQuery) {
      searchInput.value = initialQuery;
    }

    // Search history helpers
    function getHistory() {
      try {
        const data = JSON.parse(localStorage.getItem(HISTORY_KEY) || '{}');
        return Array.isArray(data.history) ? data.history : [];
      } catch {
        return [];
      }
    }

    function saveHistory(query) {
      if (!query.trim()) return;
      let history = getHistory();
      history = history.filter(item => item !== query);
      history.unshift(query);
      if (history.length > MAX_HISTORY) {
        history = history.slice(0, MAX_HISTORY);
      }
      localStorage.setItem(HISTORY_KEY, JSON.stringify({
        history,
        maxItems: MAX_HISTORY,
        updatedAt: new Date().toISOString(),
      }));
    }

    // Format star count
    function formatStars(count) {
      if (count >= 1000000) return `${(count / 1000000).toFixed(1)}m`;
      if (count >= 1000) return `${(count / 1000).toFixed(1)}k`;
      return count.toString();
    }

    // Language color mapping
    function getLanguageColor(language) {
      const colors = {
        Python: '#3572A5',
        TypeScript: '#3178c6',
        JavaScript: '#f1e05a',
        Rust: '#dea584',
        Go: '#00ADD8',
        Java: '#b07219',
        'C++': '#f34b7d',
        C: '#555555',
        'Jupyter Notebook': '#DA5B0B',
        Kotlin: '#A97BFF',
        Swift: '#F05138',
        Ruby: '#701516',
      };
      return colors[language] || '#8b949e';
    }

    // Render a single result card
    function renderCard(meta) {
      const ownerLogin = meta.owner_login || '';
      const name = meta.name || '';
      const description = meta.description_zh || meta.description || '';
      const stars = meta.stargazers_count ? formatStars(Number(meta.stargazers_count)) : '0';
      const language = meta.language || '';
      const langColor = language ? getLanguageColor(language) : '';
      const avatar = meta.owner_avatar_url || '';
      const aiScore = meta.ai_quality_score ? (Number(meta.ai_quality_score) / 10).toFixed(1) : '';

      return `
        <a href="/repo/${ownerLogin}/${name}" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-lg hover:border-[var(--color-accent)]/30">
          <div class="flex items-start gap-4">
            ${avatar ? `<img src="${avatar}" alt="${ownerLogin}" class="w-10 h-10 rounded-full shrink-0" loading="lazy" width="40" height="40" />` : ''}
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-[var(--color-text-primary)] truncate">
                <span class="text-[var(--color-text-secondary)]">${ownerLogin}</span>
                <span class="text-[var(--color-text-muted)]">/</span>
                <span>${name}</span>
              </h3>
              <p class="mt-1 text-sm text-[var(--color-text-secondary)] line-clamp-2">${description}</p>
              <div class="mt-3 flex flex-wrap items-center gap-3 text-xs">
                <span class="inline-flex items-center gap-1 text-[var(--color-star)]">
                  <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                  ${stars}
                </span>
                ${language ? `
                <span class="inline-flex items-center gap-1.5 text-[var(--color-text-secondary)]">
                  <span class="w-3 h-3 rounded-full shrink-0" style="background-color: ${langColor}"></span>
                  ${language}
                </span>` : ''}
                ${aiScore ? `
                <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full font-medium bg-[var(--color-accent)]/15 text-[var(--color-accent)]">AI ${aiScore}</span>` : ''}
              </div>
            </div>
          </div>
        </a>
      `;
    }

    // Perform search
    async function performSearch(query) {
      if (!query.trim()) {
        searchResults.innerHTML = '';
        searchStatus.classList.add('hidden');
        searchEmpty.classList.add('hidden');
        searchInitial.classList.remove('hidden');
        return;
      }

      searchInitial.classList.add('hidden');
      saveHistory(query);

      try {
        const search = await pagefind.search(query);
        const results = search.results.slice(0, 20);

        if (results.length === 0) {
          searchResults.innerHTML = '';
          searchStatus.classList.add('hidden');
          searchEmpty.classList.remove('hidden');
          return;
        }

        searchEmpty.classList.add('hidden');
        searchStatus.textContent = `找到 ${search.results.length} 个匹配项目`;
        searchStatus.classList.remove('hidden');

        const loaded = await Promise.all(results.map(r => r.data()));
        searchResults.innerHTML = `<div class="flex flex-col gap-3">${loaded.map(item => renderCard(item.meta)).join('')}</div>`;
      } catch (err) {
        console.error('Pagefind search error:', err);
        searchResults.innerHTML = `<p class="text-[var(--color-text-muted)] text-center py-8">搜索服务暂不可用（仅在构建后生效）</p>`;
        searchStatus.classList.add('hidden');
        searchEmpty.classList.add('hidden');
      }
    }

    // Run search on initial load if q param exists
    if (initialQuery) {
      performSearch(initialQuery);
    }

    // Listen for input changes with debounce
    let debounceTimer;
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const query = searchInput.value.trim();
        const url = new URL(window.location);
        if (query) {
          url.searchParams.set('q', query);
        } else {
          url.searchParams.delete('q');
        }
        window.history.replaceState({}, '', url);
        performSearch(query);
      }, 300);
    });

    // Handle Enter key
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        clearTimeout(debounceTimer);
        const query = searchInput.value.trim();
        if (query) {
          const url = new URL(window.location);
          url.searchParams.set('q', query);
          window.history.replaceState({}, '', url);
          performSearch(query);
        }
      }
    });
  </script>
</BaseLayout>
